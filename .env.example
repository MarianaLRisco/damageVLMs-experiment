# Local dataset roots (override paths in YAML)
# Set to either full dataset folder path or a parent folder containing both datasets.
DATASET_ROOT=/Users/<YOUR_USER>/www/laboratorio/dataset

# Optional dataset-specific overrides (full dataset folders)
DAMAGE_DATASET_ROOT=/Users/<YOUR_USER>/www/laboratorio/dataset/damage_dataset
CRISISMMD_ROOT=/Users/<YOUR_USER>/www/laboratorio/dataset/crisisMMD
